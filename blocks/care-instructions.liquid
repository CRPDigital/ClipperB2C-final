
{%- liquid
  assign product = closest.product

  assign bleaching = product.metafields.custom.bleaching
  assign washing = product.metafields.custom.washing
  assign tumble_dry = product.metafields.custom.tumble_dry
  assign drying = product.metafields.custom.drying
  assign ironing = product.metafields.custom.ironing

  assign has_care = false
  if bleaching != blank or washing != blank or tumble_dry != blank or drying != blank or ironing != blank
    assign has_care = true
  endif

  unless has_care
    break
  endunless
-%}

<div
  class="care-instructions spacing-style"
  style="
    {% render 'spacing-style', settings: block.settings %}
    --care-icon-size: {{ block.settings.icon_size }}px;
    --care-gap: {{ block.settings.gap }}px;
  "
  {{ block.shopify_attributes }}
>
  {%- if washing != blank -%}
    <div class="care-icon" title="{{ washing | escape }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case washing -%}
          {%- when 'Wash - 30 - Gentle - Cold' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <text x="14" y="18" text-anchor="middle" fill="currentColor" stroke="none" font-size="7" font-family="sans-serif">30</text>
            <line x1="7" y1="24" x2="21" y2="24"/>
          {%- when 'Wash - 40 Gentle - Warm' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <text x="14" y="18" text-anchor="middle" fill="currentColor" stroke="none" font-size="7" font-family="sans-serif">40</text>
            <line x1="7" y1="24" x2="21" y2="24"/>
          {%- when 'Wash - Hand Wash' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <path d="M11 17v-5M14 17v-6M17 17v-5" stroke-width="1.2"/>
            <path d="M9 14c0 4 2.5 5 5 5s5-1 5-5" fill="none" stroke-width="1.2"/>
          {%- when 'Do Not Wash' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <line x1="4" y1="4" x2="24" y2="26" stroke-width="1.6"/>
          {%- when 'Wash - 40 degree - Warm' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <text x="14" y="18" text-anchor="middle" fill="currentColor" stroke="none" font-size="7" font-family="sans-serif">40</text>
          {%- when 'Wash - 30 - mild - Cold' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <text x="14" y="18" text-anchor="middle" fill="currentColor" stroke="none" font-size="7" font-family="sans-serif">30</text>
            <line x1="7" y1="24" x2="21" y2="24"/>
            <line x1="7" y1="26.5" x2="21" y2="26.5"/>
          {%- when 'Wash - 40 Mild - Warm' -%}
            <path d="M4 8h20l-2.5 14h-15z"/>
            <text x="14" y="18" text-anchor="middle" fill="currentColor" stroke="none" font-size="7" font-family="sans-serif">40</text>
            <line x1="7" y1="24" x2="21" y2="24"/>
            <line x1="7" y1="26.5" x2="21" y2="26.5"/>
        {%- endcase -%}
      </svg>
    </div>
  {%- endif -%}

  {%- if bleaching != blank -%}
    <div class="care-icon" title="{{ bleaching | escape }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case bleaching -%}
          {%- when 'Bleach - Do not bleach' -%}
            <path d="M14 4L3 24h22z"/>
            <line x1="5" y1="5" x2="23" y2="25" stroke-width="1.6"/>
        {%- endcase -%}
      </svg>
    </div>
  {%- endif -%}

  {%- if tumble_dry != blank -%}
    <div class="care-icon" title="{{ tumble_dry | escape }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case tumble_dry -%}
          {%- when 'Tumble Dry - Do not tumble dry' -%}
            <rect x="4" y="4" width="20" height="20" rx="1"/>
            <circle cx="14" cy="14" r="7"/>
            <line x1="4" y1="4" x2="24" y2="24" stroke-width="1.6"/>
          {%- when 'Tumble Dry - Normal (low heat)' -%}
            <rect x="4" y="4" width="20" height="20" rx="1"/>
            <circle cx="14" cy="14" r="7"/>
            <circle cx="14" cy="14" r="1.5" fill="currentColor" stroke="none"/>
        {%- endcase -%}
      </svg>
    </div>
  {%- endif -%}

  {%- if drying != blank -%}
    <div class="care-icon" title="{{ drying | escape }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case drying -%}
          {%- when 'Drying - Flat dry' -%}
            <rect x="4" y="4" width="20" height="20" rx="1"/>
            <line x1="8" y1="14" x2="20" y2="14"/>
          {%- when 'Drying - Line dry' -%}
            <rect x="4" y="4" width="20" height="20" rx="1"/>
            <line x1="14" y1="8" x2="14" y2="20"/>
          {%- when 'Drying - Line dry in shade' -%}
            <rect x="4" y="4" width="20" height="20" rx="1"/>
            <line x1="14" y1="8" x2="14" y2="20"/>
            <line x1="4" y1="4" x2="10" y2="10"/>
            <line x1="9" y1="4" x2="15" y2="10"/>
        {%- endcase -%}
      </svg>
    </div>
  {%- endif -%}

  {%- if ironing != blank -%}
    <div class="care-icon" title="{{ ironing | escape }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {%- case ironing -%}
          {%- when 'Ironing - Low' -%}
            <path d="M4 20h20c1-4 1-8-1-10-1.5-1.5-4-3-9-3s-7.5 1.5-9 3c-2 2-2 6-1 10z"/>
            <circle cx="14" cy="16" r="1.5" fill="currentColor" stroke="none"/>
          {%- when 'Ironing - Medium' -%}
            <path d="M4 20h20c1-4 1-8-1-10-1.5-1.5-4-3-9-3s-7.5 1.5-9 3c-2 2-2 6-1 10z"/>
            <circle cx="11" cy="16" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="17" cy="16" r="1.5" fill="currentColor" stroke="none"/>
        {%- endcase -%}
      </svg>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .care-instructions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--care-gap, 8px);
    align-items: center;
  }

  .care-icon {
    width: var(--care-icon-size, 24px);
    height: var(--care-icon-size, 24px);
    flex-shrink: 0;
    color: currentColor;
    cursor: default;
  }

  .care-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Care instructions",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays laundry care icons based on product metafields (bleaching, washing, tumble_dry, drying, ironing)."
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "t:settings.icon_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 2,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Care instructions",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
