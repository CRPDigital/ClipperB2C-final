
{%- liquid
  assign product = closest.product
  assign linked_products = product.metafields.custom.linked_products.value

  if linked_products == blank
    break
  endif

  assign swatch_count = 0
  for lp in linked_products
    if lp.metafields.custom.swatch_color.value != blank
      assign swatch_count = swatch_count | plus: 1
    endif
  endfor

  if swatch_count <= 1
    break
  endif
-%}

<linked-swatches-component
  class="linked-swatches spacing-style"
  style="
    {% render 'spacing-style', settings: block.settings %}
    --linked-swatches-size: {{ block.settings.swatch_size }}px;
    --linked-swatches-gap: {{ block.settings.swatch_gap }}px;
    justify-content: {{ block.settings.alignment }};
  "
  {{ block.shopify_attributes }}
>
  {%- for linked_product in linked_products -%}
    {%- liquid
      assign swatch_color = linked_product.metafields.custom.swatch_color.value
      if swatch_color == blank
        continue
      endif
      assign is_current = false
      if linked_product.id == product.id
        assign is_current = true
      endif
    -%}
    <a
      href="{{ linked_product.url }}"
      class="linked-swatch{% if is_current %} linked-swatch--active{% endif %}"
      style="--swatch-bg: {{ swatch_color }};"
      title="{{ linked_product.title | escape }}"
      {% if is_current %}aria-current="true"{% endif %}
      data-featured-image-url="{{ linked_product.featured_image | image_url: width: 1000 }}"
    >
      <span class="visually-hidden">{{ linked_product.title }}</span>
    </a>
  {%- endfor -%}
</linked-swatches-component>

{% stylesheet %}
  linked-swatches-component {
    display: flex;
    flex-wrap: wrap;
    gap: var(--linked-swatches-gap, 6px);
    align-items: center;
  }

  .linked-swatch {
    display: block;
    width: var(--linked-swatches-size, 14px);
    height: var(--linked-swatches-size, 14px);
    border-radius: 50%;
    background-color: var(--swatch-bg);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
    cursor: pointer;
    flex-shrink: 0;
  }

  .linked-swatch:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.4);
    box-shadow: 0 0 0 1px rgb(var(--color-foreground-rgb) / 0.2);
  }

  .linked-swatch--active {
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 1px var(--color-foreground);
  }
{% endstylesheet %}

<script>
  if (!customElements.get('linked-swatches-component')) {
    customElements.define('linked-swatches-component', class extends HTMLElement {
      connectedCallback() {
        this.querySelectorAll('.linked-swatch').forEach(swatch => {
          swatch.addEventListener('pointerenter', this.#handlePointerEnter);
          swatch.addEventListener('pointerleave', this.#handlePointerLeave);
        });
      }

      #handlePointerEnter = (event) => {
        if (event.pointerType !== 'mouse') return;
        const imageUrl = event.currentTarget.dataset.featuredImageUrl;
        if (!imageUrl) return;

        const card = this.closest('product-card');
        if (!card) return;

        const img = card.querySelector('.product-media__image');
        if (!img) return;

        if (!this._originalSrc) {
          this._originalSrc = img.src;
          this._originalSrcset = img.srcset;
        }
        img.src = imageUrl;
        img.srcset = '';
      };

      #handlePointerLeave = (event) => {
        if (event.pointerType !== 'mouse') return;
        if (!this._originalSrc) return;

        const card = this.closest('product-card');
        if (!card) return;

        const img = card.querySelector('.product-media__image');
        if (!img) return;

        img.src = this._originalSrc;
        img.srcset = this._originalSrcset;
        this._originalSrc = null;
        this._originalSrcset = null;
      };
    });
  }
</script>

{% schema %}
