                  "type": "text",
                  "name": "t:names.heading",
                  "settings": {
                    "text": "<p>Historien begyndte lokalt<br/> - i dag arbejder vi globalt</p>",
                    "width": "fit-content",
                    "max_width": "normal",
                    "alignment": "left",
                    "type_preset": "h2",
                    "type_preset_mobile": "h3",
