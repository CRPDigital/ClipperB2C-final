            "text_YL4kGr": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<p>Strik produceret i Europa</p>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "h2",
                "type_preset_mobile": "h3",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "color": "var(--color-foreground)",
                "font_mobile": "",
                "font_size_mobile": "",
                "line_height_mobile": "",
                "letter_spacing_mobile": "",
