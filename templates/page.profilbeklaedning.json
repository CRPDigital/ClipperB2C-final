                "wrap_mobile": "",
                "color_mobile": "",
                "background": false,
                "background_color": "#00000026",
                "corner_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0,
                "mobile_padding_enabled": false,
                "mobile-padding-block-start": 0,
